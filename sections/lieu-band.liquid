{%- comment -%} lieu-band.liquid {%- endcomment -%}
<section class="section">
  <div class="wrap">
    <div class="band">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="" loading="lazy"
             style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.5;">
      {%- endif -%}
<div class="inner">
        <div class="disp">
          <span class="squash">{{ section.settings.line1 }}</span><br>
          <span class="squash">{{ section.settings.line2 }}</span>
        </div>
        <p>{{ section.settings.text }}</p>
        {%- if section.settings.btn_label != blank -%}
          <a class="btn btn-ghost btn-sm" href="{{ section.settings.btn_link }}" style="background:rgba(255,255,255,.9);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            {{ section.settings.btn_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bande lieu",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Photo de fond (optionnelle)" },
    { "type": "text", "id": "line1", "label": "Titre — ligne 1", "default": "notre bar" },
    { "type": "text", "id": "line2", "label": "Titre — ligne 2", "default": "à cookies" },
    { "type": "textarea", "id": "text", "label": "Texte", "default": "une banquette en tubes, un sol clair, une lumière franche — un espace pensé pour la dégustation sur place." },
    { "type": "text", "id": "btn_label", "label": "Bouton — libellé", "default": "découvrir le lieu" },
    { "type": "url", "id": "btn_link", "label": "Bouton — lien" }
  ],
  "presets": [{ "name": "Bande lieu" }]
}
{% endschema %}
