{%- comment -%} main-contact.liquid {%- endcomment -%}
<section class="section">
  <div class="wrap" style="max-width:640px;">
    <div class="page">
      <h1 class="disp" style="font-size:clamp(28px,6vw,40px);margin-bottom:32px;">
        <span class="squash">Contact</span>
      </h1>

      <div style="display:flex;flex-direction:column;gap:28px;">

        <div class="card" style="padding:24px 28px;display:flex;flex-direction:column;gap:6px;">
          <span class="seclabel acc" style="margin-bottom:8px;">Adresse</span>
          <span style="font:500 16px/1.5 var(--ui);color:var(--ink);">texture cookies</span>
          <span style="font:400 15px/1.5 var(--ui);color:var(--ink-soft);">4 rue Adrien Dubouché</span>
          <span style="font:400 15px/1.5 var(--ui);color:var(--ink-soft);">87000 Limoges</span>
          <a href="https://maps.google.com/?q=4+rue+Adrien+Dubouché+87000+Limoges"
             target="_blank" rel="noopener"
             style="margin-top:10px;font:500 13px/1 var(--ui);color:var(--accent);text-decoration:none;">
            Voir sur Google Maps →
          </a>
        </div>

        <div class="card" style="padding:24px 28px;display:flex;flex-direction:column;gap:6px;">
          <span class="seclabel acc" style="margin-bottom:8px;">Horaires</span>
          <span style="font:400 15px/1.5 var(--ui);color:var(--ink-soft);">Mardi – dimanche · 10h – 19h</span>
          <span style="font:400 15px/1.5 var(--ui);color:var(--ink-soft);">Fermé le lundi</span>
        </div>

        <div class="card" style="padding:24px 28px;display:flex;flex-direction:column;gap:6px;">
          <span class="seclabel acc" style="margin-bottom:8px;">Nous écrire</span>
          <a href="mailto:choncote.coffee@gmail.com"
             style="font:500 15px/1 var(--ui);color:var(--accent);text-decoration:none;">
            choncote.coffee@gmail.com
          </a>
          <span style="font:400 13px/1.4 var(--ui);color:var(--mono);margin-top:4px;">On répond généralement sous 24h.</span>
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Contact", "settings": [] }
{% endschema %}
