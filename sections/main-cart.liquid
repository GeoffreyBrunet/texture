{%- comment -%} main-cart.liquid — page panier (/cart) {%- endcomment -%}
<section class="section">
  <div class="wrap" style="max-width:760px;">
    <h1 class="disp" style="font-size:clamp(28px,6vw,40px);"><span class="squash">panier</span>
      {%- if cart.item_count > 0 %} <span class="spark">{{ cart.item_count }}</span>{% endif -%}
    </h1>

    {%- if cart.item_count == 0 -%}
      <div class="cart-empty" style="min-height:280px;">
<p style="font:500 15px/1.4 var(--ui);color:var(--ink-soft);text-transform:lowercase;margin:0;">votre panier est vide.</p>
        <a class="btn btn-acc" href="{{ routes.all_products_collection_url }}">voir la carte</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart-form" class="mt18">
        {%- for item in cart.items -%}
          <div class="cart-line">
            <a class="thumb" href="{{ item.url }}">{% render 'product-media', product: item.product %}</a>
            <div style="flex:1;min-width:0;">
              <div class="flex between gap8">
                <a class="name" href="{{ item.url }}" style="font:500 14px/1.2 var(--ui);text-transform:lowercase;">{{ item.product.title | downcase }}</a>
                <span class="dymo">{{ item.final_line_price | money }}</span>
              </div>
              {%- unless item.variant.title contains 'Default' -%}
                <div style="font:400 11px/1.2 var(--ui);color:var(--mono);text-transform:lowercase;margin-top:4px;">{{ item.variant.title | downcase }}</div>
              {%- endunless -%}
              <div class="flex between" style="margin-top:10px;">
                <div class="stepper" data-cart-stepper data-key="{{ item.key }}">
                  <button type="button" class="minus" aria-label="moins">–</button>
                  <span class="q">{{ item.quantity }}</span>
                  <button type="button" class="plus" aria-label="plus">+</button>
                </div>
                <a class="remove" href="{{ item.url_to_remove }}">retirer</a>
              </div>
            </div>
          </div>
        {%- endfor -%}

        <div class="card note-band" style="margin-top:18px;">
          <span style="font-size:18px;">🍪</span>
          <span style="font:400 12px/1.3 var(--ui);color:var(--ink-soft);text-transform:lowercase;">retrait sur place · prêt en ~15 min</span>
        </div>

        <div class="flex between" style="margin:20px 0 14px;">
          <span class="seclabel acc">total ttc</span>
          <span class="dymo lg">{{ cart.total_price | money }}</span>
        </div>
        <button type="submit" name="checkout" class="btn btn-acc btn-block">commander</button>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Panier", "settings": [] }
{% endschema %}
