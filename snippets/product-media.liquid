{%- comment -%}
  product-media.liquid
  params: product, (optional) note
  Affiche la photo produit si elle existe, sinon le disque dégradé
  Y2K basé sur les metafields couleur custom.flavor_base / flavor_top / speck.
{%- endcomment -%}
{%- assign base = product.metafields.custom.flavor_base | default: '#b9a17e' -%}
{%- assign top = product.metafields.custom.flavor_top | default: '#d8c6a6' -%}
{%- assign speck = product.metafields.custom.speck | default: '#6e5a3a' -%}
<div class="pmedia">
  {%- if product.featured_image != blank -%}
    <img src="{{ product.featured_image | image_url: width: 700 }}"
         alt="{{ product.featured_image.alt | escape | default: product.title }}"
         loading="lazy" width="700" height="700">
  {%- else -%}
    <div class="disc-wrap">
      <div class="disc" style="background:radial-gradient(60% 55% at 38% 32%, {{ top }}, {{ base }} 72%, color-mix(in srgb,{{ base }} 70%,#000));">
        <span class="speck" style="left:30%;top:38%;width:6px;height:6px;background:{{ speck }};opacity:.8;"></span>
        <span class="speck" style="left:62%;top:30%;width:5px;height:5px;background:{{ speck }};opacity:.8;"></span>
        <span class="speck" style="left:48%;top:56%;width:7px;height:7px;background:{{ speck }};opacity:.8;"></span>
        <span class="speck" style="left:70%;top:62%;width:5px;height:5px;background:{{ speck }};opacity:.8;"></span>
        <span class="speck" style="left:36%;top:70%;width:6px;height:6px;background:{{ speck }};opacity:.8;"></span>
        <span class="speck" style="left:58%;top:44%;width:5px;height:5px;background:{{ speck }};opacity:.8;"></span>
        <span class="speck" style="left:24%;top:54%;width:7px;height:7px;background:{{ speck }};opacity:.8;"></span>
        <span class="gloss"></span>
      </div>
    </div>
    {%- if note -%}<span class="ph-note">{{ note }}</span>{%- endif -%}
  {%- endif -%}
</div>
