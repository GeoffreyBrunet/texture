{%- comment -%} cart-drawer.liquid — tiroir latéral, rempli en AJAX par theme.js {%- endcomment -%}
<div class="cart-drawer-scrim" data-cart-scrim></div>
<aside class="cart-drawer" data-cart-drawer aria-hidden="true" aria-label="panier">
  <div class="head">
    <h2 class="disp" style="font-size:22px;margin:0;"><span class="squash">panier</span> <span class="spark" data-drawer-count></span></h2>
    <button class="closebtn" data-cart-close aria-label="fermer">✕</button>
  </div>

  <div class="items" data-drawer-items>
    <div class="cart-empty">
<p style="font:500 15px/1.4 var(--ui);color:var(--ink-soft);text-transform:lowercase;margin:0;">votre panier est vide.</p>
      <a class="btn btn-acc" href="{{ routes.all_products_collection_url }}" data-cart-close>voir la carte</a>
    </div>
  </div>

  <div class="cart-foot" data-drawer-foot hidden>
    <div class="card note-band" style="margin:0 0 14px;">
      <span style="font-size:18px;">🍪</span>
      <span style="font:400 12px/1.3 var(--ui);color:var(--ink-soft);text-transform:lowercase;">retrait sur place · prêt en ~15 min</span>
    </div>
    <div class="flex between" style="margin-bottom:14px;">
      <span class="seclabel acc">total ttc</span>
      <span class="dymo lg" data-drawer-total></span>
    </div>
    <a class="btn btn-acc btn-block" href="{{ routes.cart_url }}">commander</a>
  </div>
</aside>
