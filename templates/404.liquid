{%- comment -%} 404.liquid {%- endcomment -%}
<section class="section">
  <div class="wrap">
    <div class="page" style="text-align:center;min-height:300px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;">
      <h1 class="disp" style="font-size:clamp(28px,6vw,40px);"><span class="squash">{{ 'general.404.title' | t }}</span></h1>
      <p class="manifesto" style="text-align:center;">{{ 'general.404.subtext' | t }}</p>
      <a class="btn btn-acc" href="{{ routes.root_url }}">{{ 'general.404.link' | t }}</a>
    </div>
  </div>
</section>
